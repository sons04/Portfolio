    "express": "^5.2.1",
    "nodemailer": "^8.0.4",
    "postprocessing": "^6.37.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.179.0",
    "topojson-client": "^3.1.0",
    "world-atlas": "^2.0.2",
